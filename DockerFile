# Usamos Node 20 LTS (Slim es más ligero y seguro que Ubuntu para JS)
FROM node:20-slim AS base

# Instalamos dependencias del sistema necesarias (OpenSSL para DBs)
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copiamos archivos de dependencias primero (aprovecha la caché de capas)
COPY package.json yarn.lock ./

# Instalamos TODAS las dependencias para poder compilar TS (si fuera necesario)
# Si solo quieres producción usa: RUN yarn install --frozen-lockfile --production
RUN yarn install --frozen-lockfile

# Copiamos el resto del código (asegúrate de que src esté en la raíz ahora)
COPY . .

# Si usas TypeScript, aquí deberías añadir: RUN yarn build
# Y luego limpiar dependencias de desarrollo para que la imagen pese menos.

# Usuario no raíz por seguridad (Node ya trae el usuario 'node')
USER node

EXPOSE 3000

# Comando de inicio
CMD ["yarn", "start"]
